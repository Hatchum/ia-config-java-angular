{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_generated": "GENERATED FROM .ai/config — DO NOT EDIT DIRECTLY",
  "permissions": {
    "deny": [
      "Read(./**/target/**)",
      "Read(./**/dist/**)",
      "Read(./**/build/**)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(del /f *)",
      "Bash(del /q *)",
      "Bash(del /s *)",
      "Bash(rd /s *)",
      "Bash(rmdir /s *)",
      "Bash(Remove-Item *)",
      "Bash(ri -r*)",
      "Bash(format *)",
      "Bash(Format-Volume*)",
      "Bash(Clear-Disk*)",
      "Bash(diskpart*)",
      "Bash(shutdown *)",
      "Bash(Stop-Computer*)",
      "Bash(Restart-Computer*)",
      "Bash(taskkill /f *)",
      "Bash(Stop-Process *)",
      "Bash(runas *)",
      "Bash(psql*)",
      "Bash(pg_dump*)",
      "Bash(pg_restore*)",
      "Bash(pg_dumpall*)",
      "Bash(createdb*)",
      "Bash(dropdb*)",
      "Bash(mysql*)",
      "Bash(mysqldump*)",
      "Bash(mysqladmin*)",
      "Bash(mariadb*)",
      "Bash(sqlite3*)",
      "Bash(mongo*)",
      "Bash(redis-cli*)",
      "Bash(sqlcmd*)",
      "Bash(sqlplus*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)"
    ],
    "allow": [
      "Bash(mvn *)",
      "Bash(./mvnw *)",
      "Bash(mvnw *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(gradlew *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/lint-format.sh\""
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/log-changes.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "shell": "bash",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-lint.sh\""
          }
        ]
      }
    ]
  }
}
